# .editorconfig

root = true

[*.cs]
charset = utf-8
indent_style = space
indent_size = 4
tab_width = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
csharp_style_var_elsewhere = true:suggestion
csharp_style_var_for_built_in_types = true:suggestion
csharp_style_prefer_inferred_anonymous_type_member_names = true:suggestion
csharp_style_prefer_inferred_tuple_element_names = true:suggestion

[*.axaml]
indent_style = space
indent_size = 4
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.html]
indent_style = space
indent_size = 2
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.json]
indent_style = space
indent_size = 2
insert_final_newline = true

[*.md]
trim_trailing_whitespace = true
insert_final_newline = true