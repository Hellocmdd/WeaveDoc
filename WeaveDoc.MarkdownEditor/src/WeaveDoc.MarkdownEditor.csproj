<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.1" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.1" />
    <PackageReference Include="Avalonia.Markup.Xaml.Loader" Version="12.0.1" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="12.0.1" />
    <!-- WebView2 runtime package for embedding Monaco (Windows WebView2) -->
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.1343.22" />
    <!-- Avalonia.ReactiveUI removed because 12.0.1 not published -->
  </ItemGroup>
  
<ItemGroup>
  <None Include="Assets\**\*">
    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
  </None>
</ItemGroup>

  <ItemGroup>
    <!-- Copy Monaco assets to output so the WebView can load them via file:// -->
    <Content Include="Assets\monaco-editor\**\*" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>
</Project>