<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WeaveDoc.MarkdownEditor.Controls"
        xmlns:viewModels="clr-namespace:WeaveDoc.MarkdownEditor.ViewModels"
        x:Class="WeaveDoc.MarkdownEditor.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Title="WeaveDoc Markdown Editor" Width="1000" Height="700"
        MinWidth="600" MinHeight="400">
  
  <DockPanel>
    <!-- 菜单栏 -->
    <Menu DockPanel.Dock="Top">
      <MenuItem Header="_File">
        <MenuItem Header="_Open" Click="OpenFile_Click" />
        <MenuItem Header="_Save" Click="SaveFile_Click" />
        <MenuItem Header="Save _As" Click="SaveAsFile_Click" />
      </MenuItem>
    </Menu>
    
    <!-- 工具栏 -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Background="#E0E0E0" Margin="4" Spacing="2">
      <Button Name="BoldButton" Click="BoldButton_Click" ToolTip.Tip="Bold" Width="28" Height="28">
        <TextBlock FontWeight="Bold" FontSize="12">B</TextBlock>
      </Button>
      <Button Name="ItalicButton" Click="ItalicButton_Click" ToolTip.Tip="Italic" Width="28" Height="28">
        <TextBlock FontStyle="Italic" FontSize="12">I</TextBlock>
      </Button>
      <Button Name="UnderlineButton" Click="UnderlineButton_Click" ToolTip.Tip="Underline" Width="28" Height="28">
        <TextBlock TextDecorations="Underline" FontSize="12">U</TextBlock>
      </Button>
      <Rectangle Width="1" Height="20" Fill="#CCCCCC" Margin="4,0" />
      <Button Name="H1Button" Click="H1Button_Click" ToolTip.Tip="Heading 1" Width="36" Height="28">
        <TextBlock FontSize="10" FontWeight="Bold">H1</TextBlock>
      </Button>
      <Button Name="H2Button" Click="H2Button_Click" ToolTip.Tip="Heading 2" Width="36" Height="28">
        <TextBlock FontSize="10" FontWeight="Bold">H2</TextBlock>
      </Button>
      <Button Name="H3Button" Click="H3Button_Click" ToolTip.Tip="Heading 3" Width="36" Height="28">
        <TextBlock FontSize="10" FontWeight="Bold">H3</TextBlock>
      </Button>
      <Rectangle Width="1" Height="20" Fill="#CCCCCC" Margin="4,0" />
      <Button Name="BulletListButton" Click="BulletListButton_Click" ToolTip.Tip="Bullet List" Width="50" Height="28">
        <TextBlock FontSize="10">• List</TextBlock>
      </Button>
      <Button Name="NumberedListButton" Click="NumberedListButton_Click" ToolTip.Tip="Numbered List" Width="58" Height="28">
        <TextBlock FontSize="10">1. List</TextBlock>
      </Button>
      <Rectangle Width="1" Height="20" Fill="#CCCCCC" Margin="4,0" />
      <Button Name="CodeBlockButton" Click="CodeBlockButton_Click" ToolTip.Tip="Code Block" Width="40" Height="28">
        <TextBlock FontSize="10">&lt;/&gt;</TextBlock>
      </Button>
      <Button Name="LinkButton" Click="LinkButton_Click" ToolTip.Tip="Link" Width="28" Height="28">
        <TextBlock FontSize="14">🔗</TextBlock>
      </Button>
      <Button Name="ImageButton" Click="ImageButton_Click" ToolTip.Tip="Image" Width="28" Height="28">
        <TextBlock FontSize="14">🖼️</TextBlock>
      </Button>
    </StackPanel>
    
    <!-- 主内容区域 -->
    <Grid>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      
      <!-- 左侧 Monaco 编辑器 -->
      <Border Grid.Column="0" Margin="8,8,4,8" Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1">
        <controls:MonacoEditorControl x:Name="MonacoEditor" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
      </Border>

      <!-- 右侧预览 -->
      <Border Grid.Column="1" Margin="4,8,8,8" Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
        <controls:PreviewWebViewControl x:Name="PreviewWebView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" HtmlContent="{Binding PreviewHtml}" />
      </Border>
    </Grid>
  </DockPanel>
</Window>
