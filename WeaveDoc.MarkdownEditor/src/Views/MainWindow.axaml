<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WeaveDoc Markdown Editor" Width="1000" Height="700"
        MinWidth="600" MinHeight="400">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>
    
    <!-- 菜单 -->
    <Menu Grid.Row="0">
      <MenuItem Header="文件">
        <MenuItem Header="打开..." Click="OpenFile_Click" />
        <Separator />
        <MenuItem Header="保存" Click="SaveFile_Click" />
        <MenuItem Header="另存为..." Click="SaveAsFile_Click" />
      </MenuItem>
    </Menu>
    
    <!-- 工具栏 -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="8" Spacing="4">
      <Button Content="B" FontWeight="Bold" Click="BoldButton_Click" />
      <Button Content="I" FontStyle="Italic" Click="ItalicButton_Click" />
      <Button Content="U" Click="UnderlineButton_Click" />
      <Separator Width="1" Height="20" Margin="4,0,4,0" />
      <Button Content="#" Click="H1Button_Click" />
      <Button Content="##" Click="H2Button_Click" />
      <Button Content="###" Click="H3Button_Click" />
      <Separator Width="1" Height="20" Margin="4,0,4,0" />
      <Button Content="•" Click="BulletListButton_Click" />
      <Button Content="1." Click="NumberedListButton_Click" />
      <Separator Width="1" Height="20" Margin="4,0,4,0" />
      <Button Content="```" Click="CodeBlockButton_Click" />
      <Button Content="[链接]()" Click="LinkButton_Click" />
      <Button Content="![]()" Click="ImageButton_Click" />
    </StackPanel>
    
    <!-- 主内容区域 -->
    <Grid Grid.Row="2" Margin="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>
      
      <!-- 左侧编辑器 -->
      <TextBox Grid.Column="0"
               Name="EditorTextBox"
               Text="# Hello WeaveDoc!

Start typing markdown here..." 
               TextWrapping="Wrap" 
               AcceptsReturn="True" 
               FontFamily="Consolas" 
               FontSize="14" 
               Background="#1E1E1E" 
               Foreground="White" 
               Padding="8" 
               CaretBrush="White"
               Margin="0,0,4,0" />

      <!-- 右侧预览 -->
      <ScrollViewer Grid.Column="1" 
                    Background="White"
                    Margin="4,0,0,0">
        <TextBlock Text="# Hello WeaveDoc!

Start typing markdown here..." 
                   FontFamily="Segoe UI" 
                   FontSize="14" 
                   TextWrapping="Wrap"
                   Foreground="Black"
                   Padding="8" />
      </ScrollViewer>
    </Grid>
  </Grid>
</Window>