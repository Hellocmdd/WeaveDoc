<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WeaveDoc.MarkdownEditor.Controls.MonacoEditorControl"
             Width="*" Height="*">
  <!-- Placeholder panel where native WebView2 will be positioned over/inside -->
  <Border x:Name="HostBorder" Background="Transparent">
    <TextBlock Text="Loading Monaco..." HorizontalAlignment="Center" VerticalAlignment="Center"/>
  </Border>
</UserControl>