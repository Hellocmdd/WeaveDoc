<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WeaveDoc.MarkdownEditor.Controls.MonacoEditorControl"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
  <!-- Placeholder panel where native WebView2 will be positioned over/inside -->
  <Border x:Name="HostBorder" Background="Transparent"
          HorizontalAlignment="Stretch"
          VerticalAlignment="Stretch">
  </Border>
</UserControl>