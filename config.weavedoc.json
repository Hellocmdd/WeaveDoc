{
  "keywords": [
    "Zotero",
    "Paperpile",
    "Paperlib",
    "Overleaf",
    "Typst",
    "Obsidian",
    "Logseq",
    "MarkText",
    "Elicit",
    "Consensus",
    "Research Rabbit"
  ],
  "keyword_aliases": {
    "Research Rabbit": [
      "ResearchRabbit"
    ],
    "Consensus": [
      "Consensus AI"
    ],
    "Elicit": [
      "Elicit AI"
    ]
  },
  "review_terms": [
    "review",
    "experience",
    "recommend",
    "pros",
    "cons"
  ],
  "requirement_terms": [
    "workflow",
    "markdown",
    "pdf",
    "docx",
    "export",
    "template",
    "citation",
    "bibtex",
    "annotation",
    "offline",
    "local",
    "privacy",
    "linux",
    "windows",
    "需求",
    "工作流",
    "导出",
    "模板",
    "批注",
    "本地",
    "离线",
    "隐私"
  ],
  "request_timeout_seconds": 20,
  "max_workers": 4,
  "sources": [
    {
      "name": "reddit-weavedoc-requirements",
      "source_type": "reddit_search",
      "subreddits": [
        "academia",
        "PhD",
        "gradschool",
        "research",
        "ObsidianMD",
        "Zotero",
        "LaTeX"
      ],
      "search_terms": [
        "workflow",
        "review",
        "offline"
      ],
      "search_sort": "relevance",
      "search_limit": 10,
      "include_comments": true,
      "max_comments": 8,
      "crawl_delay_seconds": 1.5,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    },
    {
      "name": "v2ex-weavedoc-requirements",
      "source_type": "v2ex_topics",
      "start_urls": [
        "https://www.v2ex.com/go/create",
        "https://www.v2ex.com/go/programmer",
        "https://www.v2ex.com/go/share"
      ],
      "search_limit": 30,
      "max_comments": 8,
      "max_pages": 2,
      "crawl_delay_seconds": 1.5,
      "headers": {
        "Accept-Language": "zh-CN,zh;q=0.9"
      }
    },
    {
      "name": "hn-weavedoc-requirements",
      "source_type": "hn_algolia_search",
      "search_tags": [
        "story",
        "comment"
      ],
      "search_limit": 20,
      "crawl_delay_seconds": 1.0,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    },
    {
      "name": "stackoverflow-weavedoc-requirements",
      "source_type": "stackoverflow_search",
      "search_site": "stackoverflow",
      "search_tags": [
        "markdown",
        "pdf",
        "latex",
        "zotero"
      ],
      "search_limit": 20,
      "crawl_delay_seconds": 1.0,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    },
    {
      "name": "github-weavedoc-requirements",
      "source_type": "github_issues_search",
      "github_search_qualifiers": [
        "is:issue",
        "label:enhancement",
        "label:feature"
      ],
      "search_limit": 20,
      "crawl_delay_seconds": 2.0
    },
    {
      "name": "duckduckgo-weavedoc-requirements",
      "source_type": "duckduckgo_html_search",
      "search_domains": [
        "forum.zotero.org",
        "reddit.com",
        "stackoverflow.com"
      ],
      "search_limit": 15,
      "crawl_delay_seconds": 3.0
    },
    {
      "name": "producthunt-weavedoc-requirements",
      "source_type": "producthunt_reviews",
      "start_urls": [
        "https://www.producthunt.com/products/zotero",
        "https://www.producthunt.com/products/obsidian"
      ],
      "max_comments": 10,
      "crawl_delay_seconds": 2.0
    }
  ]
}
