{
  "keywords": [
    "Zotero",
    "Mendeley",
    "EndNote",
    "Overleaf",
    "Typst",
    "Pandoc",
    "BibTeX",
    "citation manager",
    "reference manager"
  ],
  "review_terms": [
    "review",
    "experience",
    "pros",
    "cons",
    "recommend",
    "issue",
    "bug"
  ],
  "requirement_terms": [
    "workflow",
    "citation",
    "bibtex",
    "markdown",
    "pdf",
    "docx",
    "export",
    "offline",
    "privacy",
    "linux",
    "windows"
  ],
  "request_timeout_seconds": 20,
  "max_workers": 6,
  "sources": [
    {
      "name": "github-issues-expanded",
      "source_type": "github_issues_search",
      "search_terms": [
        "review",
        "experience",
        "citation",
        "export",
        "workflow",
        "bug",
        "issue"
      ],
      "github_search_qualifiers": [
        "is:issue",
        "state:open"
      ],
      "search_limit": 30,
      "crawl_delay_seconds": 0.6,
      "headers": {
        "Accept": "application/vnd.github+json",
        "User-Agent": "paper-tool-feedback-crawler"
      }
    },
    {
      "name": "v2ex-expanded-fallback",
      "source_type": "v2ex_topics",
      "start_urls": [
        "https://www.v2ex.com/go/create",
        "https://www.v2ex.com/go/programmer"
      ],
      "search_limit": 20,
      "max_comments": 6,
      "max_pages": 1,
      "crawl_delay_seconds": 1.0,
      "headers": {
        "Accept-Language": "zh-CN,zh;q=0.9"
      }
    }
  ]
}
