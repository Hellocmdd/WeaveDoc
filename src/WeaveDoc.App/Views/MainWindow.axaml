<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:WeaveDoc.App.Views"
        x:Class="WeaveDoc.App.Views.MainWindow"
        Title="WeaveDoc"
        Width="1180" Height="820"
        Background="#F7F8FC"
        WindowStartupLocation="CenterScreen">
    <TabControl>
        <TabItem Header="文档转换">
            <views:ConvertTab x:Name="ConvertTabControl" />
        </TabItem>
        <TabItem Header="模板管理">
            <views:TemplateTab x:Name="TemplateTabControl" />
        </TabItem>
        <TabItem Header="RAG 问答">
            <views:RagTab x:Name="RagTabControl" />
        </TabItem>
    </TabControl>
</Window>
