<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WeaveDoc.Converter.Ui.Views.ConvertTab">
    <ScrollViewer Background="#F7F8FC">
        <StackPanel Spacing="14" Margin="24,20">

            <!-- Card 1: 选择文件 -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="18,16"
                    BorderBrush="#ECECF0" BorderThickness="1"
                    BoxShadow="0 1 3 0 #0F000000">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="24" Height="24" CornerRadius="12" Background="#4A6FA5">
                            <TextBlock Text="1" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="选择文件" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="MdPathBox" Grid.Column="0" IsReadOnly="True"
                                 Foreground="#4A5568" FontSize="13" Padding="9,8"
                                 BorderBrush="#DCE1E8" BorderThickness="1"
                                 CornerRadius="6" Background="#FAFBFC"
                                 Watermark="点击浏览选择 .md 文件..." />
                        <Button x:Name="BrowseMdButton" Grid.Column="1" Content="浏览..."
                                Margin="10,0,0,0" FontSize="13" FontWeight="Medium"
                                Padding="16,8" Foreground="#4A5568" Background="#F0F2F5"
                                BorderBrush="#DCE1E8" BorderThickness="1" CornerRadius="6" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card 2: 选择模板与格式 -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="18,16"
                    BorderBrush="#ECECF0" BorderThickness="1"
                    BoxShadow="0 1 3 0 #0F000000">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="24" Height="24" CornerRadius="12" Background="#4A6FA5">
                            <TextBlock Text="2" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="选择模板与格式" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <ComboBox x:Name="TemplateCombo" Grid.Column="0"
                                  HorizontalAlignment="Stretch"
                                  DisplayMemberBinding="{Binding TemplateName}" />
                        <Border Grid.Column="1" BorderBrush="#DCE1E8" BorderThickness="1"
                                CornerRadius="6" ClipToBounds="True">
                            <StackPanel Orientation="Horizontal">
                                <Button x:Name="FormatDocxBtn" Content="DOCX"
                                        FontSize="13" FontWeight="SemiBold"
                                        Padding="18,7"
                                        Foreground="White" Background="#4A6FA5"
                                        BorderThickness="0" CornerRadius="0" />
                                <Button x:Name="FormatPdfBtn" Content="PDF"
                                        FontSize="13" FontWeight="Normal"
                                        Padding="18,7"
                                        Foreground="#718096" Background="#F7F8FC"
                                        BorderThickness="0" CornerRadius="0" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card 3: 输出设置 -->
            <Border Background="#FFFFFF" CornerRadius="10" Padding="18,16"
                    BorderBrush="#ECECF0" BorderThickness="1"
                    BoxShadow="0 1 3 0 #0F000000">
                <StackPanel Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="24" Height="24" CornerRadius="12" Background="#4A6FA5">
                            <TextBlock Text="3" Foreground="White" FontSize="12" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="输出设置" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#2C3E50" VerticalAlignment="Center"/>
                    </StackPanel>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="OutputDirBox" Grid.Column="0" IsReadOnly="True"
                                 Foreground="#4A5568" FontSize="13" Padding="9,8"
                                 BorderBrush="#DCE1E8" BorderThickness="1"
                                 CornerRadius="6" Background="#FAFBFC"
                                 Watermark="选择输出目录..." />
                        <Button x:Name="BrowseOutputButton" Grid.Column="1" Content="浏览..."
                                Margin="10,0,0,0" FontSize="13" FontWeight="Medium"
                                Padding="16,8" Foreground="#4A5568" Background="#F0F2F5"
                                BorderBrush="#DCE1E8" BorderThickness="1" CornerRadius="6" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 主按钮 -->
            <Button x:Name="ConvertButton" Content="开始转换"
                    HorizontalAlignment="Center" Padding="56,12"
                    FontSize="15" FontWeight="Bold"
                    Foreground="White" Background="#4A6FA5"
                    CornerRadius="8" />

            <!-- 状态栏 -->
            <Border Background="#FFFFFF" CornerRadius="8" Padding="10,16"
                    BorderBrush="#ECECF0" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="8"
                            HorizontalAlignment="Center">
                    <Border x:Name="StatusDot" Width="8" Height="8" CornerRadius="4"
                            Background="#52C41A" VerticalAlignment="Center" />
                    <TextBlock x:Name="StatusLabel" Text="就绪"
                               FontSize="13" FontWeight="Medium"
                               Foreground="#52C41A" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- 日志区域（默认隐藏，失败时显示） -->
            <TextBox x:Name="LogBox" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="Wrap" FontSize="12" Foreground="#666666"
                     IsVisible="False"
                     ScrollViewer.VerticalScrollBarVisibility="Auto" />

        </StackPanel>
    </ScrollViewer>
</UserControl>
