{
  "keywords": [
    "Zotero",
    "Mendeley",
    "Overleaf",
    "BibTeX",
    "reference manager"
  ],
  "review_terms": [
    "review",
    "experience",
    "pros",
    "cons",
    "recommend"
  ],
  "requirement_terms": [
    "workflow",
    "citation",
    "bibtex",
    "markdown",
    "pdf",
    "docx",
    "export",
    "offline",
    "privacy",
    "linux",
    "windows"
  ],
  "request_timeout_seconds": 20,
  "max_workers": 6,
  "sources": [
    {
      "name": "v2ex-fast",
      "source_type": "v2ex_topics",
      "start_urls": [
        "https://www.v2ex.com/go/create",
        "https://www.v2ex.com/go/programmer"
      ],
      "search_limit": 20,
      "max_comments": 8,
      "max_pages": 1,
      "crawl_delay_seconds": 0.8,
      "headers": {
        "Accept-Language": "zh-CN,zh;q=0.9"
      }
    },
    {
      "name": "hn-fast",
      "source_type": "hn_algolia_search",
      "search_tags": [
        "story",
        "comment"
      ],
      "search_limit": 10,
      "crawl_delay_seconds": 0.6,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    },
    {
      "name": "so-fast",
      "source_type": "stackoverflow_search",
      "search_site": "stackoverflow",
      "search_limit": 10,
      "crawl_delay_seconds": 0.6,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    },
    {
      "name": "tex-fast",
      "source_type": "stackoverflow_search",
      "search_site": "tex",
      "search_limit": 10,
      "crawl_delay_seconds": 0.6,
      "headers": {
        "Accept-Language": "en-US,en;q=0.9"
      }
    }
  ]
}
